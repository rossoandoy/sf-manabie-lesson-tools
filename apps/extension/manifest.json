{
  "manifest_version": 3,
  "name": "Manabie Lesson Tools",
  "version": "0.3.0",
  "description": "Salesforce API-first lesson schedule and closed date registration for Manabie (Sandbox MVP)",
  "permissions": ["storage", "cookies"],
  "host_permissions": [
    "https://*.my.salesforce.com/*",
    "https://*.salesforce.com/*",
    "https://*.force.com/*",
    "https://login.salesforce.com/*",
    "https://test.salesforce.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://*.my.salesforce.com https://*.salesforce.com https://*.force.com https://login.salesforce.com https://test.salesforce.com"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.my.salesforce.com/*",
        "https://*.salesforce.com/*",
        "https://*.force.com/*"
      ],
      "js": ["content/detector.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["BUILD_INFO.json", "data/discovery-trg2-extuat.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
